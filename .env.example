# ========================================
# Cryptex Trading System Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# ========================================
# Binance API (Required for Arbitrage + Spot Auto Trading)
# ========================================
# Get your API key at: https://www.binance.com/en/my/settings/api-management
# Required permissions: Spot Trading, Futures Trading
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ========================================
# OKX API (Optional - Alternative price source)
# ========================================
# Get your API key at: https://www.okx.com/account/my-api
# OKX works in most regions where Binance is blocked
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# ========================================
# Polymarket API (Required for Prediction System)
# ========================================
# Docs: https://docs.polymarket.com/api-reference/authentication
#
# === Recommended: Use Official SDK ===
# Install: pip install py-clob-client
# Only need private key, SDK auto-derives API credentials
#
# Get private key:
# - Magic/Email login: https://reveal.magic.link/polymarket
# - MetaMask: Settings -> Account Details -> Export Private Key
POLY_PRIVATE_KEY=0x_your_eoa_private_key_here
POLY_PROXY_WALLET=your_gnosis_safe_proxy_wallet_address

# === Optional: Manually configured derived credentials ===
# If already derived via SDK, save here
POLY_API_KEY=your_poly_api_key_here
POLY_API_SECRET=your_poly_api_secret_here
POLY_API_PASSPHRASE=your_poly_api_passphrase_here

# ========================================
# System Configuration
# ========================================

# Demo mode - use simulated data when API is unavailable
POLYMARKET_DEMO_MODE=false

# Spot auto trading safety switch
# true: simulated orders only, false: allow live spot orders
SPOT_DRY_RUN=true

# ========================================
# Arbitrage Strategy Parameters (Optional)
# ========================================

# Funding Rate Arbitrage
# FUNDING_RATE_THRESHOLD=0.03       # Minimum funding rate (%)
# FUNDING_NEGATIVE_EXIT=true        # Exit when funding turns negative

# Basis Arbitrage
# BASIS_ANNUALIZED_THRESHOLD=15.0   # Minimum annualized return (%)
# BASIS_DAYS_BEFORE_EXPIRY=3        # Days before expiry to exit

# Stablecoin Arbitrage
# STABLECOIN_SPREAD_THRESHOLD=0.5   # Minimum spread (%)

# ========================================
# Risk Control Parameters (Optional)
# ========================================

# MAX_POSITION_PCT=50               # Max position as % of account
# MAX_SINGLE_STRATEGY_PCT=25        # Max per-strategy exposure (%)
# STOP_LOSS_PCT=3                   # Stop loss threshold (%)
# MIN_MARGIN_RATIO=5                # Minimum margin ratio (%)

# ========================================
# Proxy Settings (Optional)
# ========================================
# For users behind firewall
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

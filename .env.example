# Polymarket Crypto Predictor Environment Variables
# Copy this file to .env and fill in your values

# Binance API Key (optional - for better rate limits)
# Get your API key at: https://www.binance.com/en/my/settings/api-management
# Note: Binance may be blocked in certain regions (US, some EU countries)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# OKX API Key (recommended - global exchange, fewer restrictions)
# Get your API key at: https://www.okx.com/account/my-api
# OKX works in most regions where Binance is blocked
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# Demo mode (set to false to use real API data)
POLYMARKET_DEMO_MODE=false

# Proxy settings (optional - for users behind firewall)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890